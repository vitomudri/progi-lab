{
    "name": "kuhari",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "workspaces": [
        "backend/",
        "frontend/"
    ],
    "scripts": {
        "dev:backend": "npm --workspace backend run dev",
        "dev:frontend": "npm --workspace frontend run dev",
        "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
        "build": "npm --workspaces run build",
        "lint": "npm --workspaces run lint"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/jsonwebtoken": "^9.0.10",
        "concurrently": "^8.2.0",
        "eslint": "^8.56.0",
        "tsx": "^4.20.6",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "argon2": "^0.44.0",
        "cookie-parser": "^1.4.7",
        "jsonwebtoken": "^9.0.2"
    }
}
